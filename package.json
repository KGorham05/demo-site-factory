{
  "name": "demo-site-factory",
  "version": "0.1.0",
  "private": true,
  "description": "Automated demo site factory for local businesses without websites",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "find-leads": "tsx src/lead-finder/src/index.ts",
