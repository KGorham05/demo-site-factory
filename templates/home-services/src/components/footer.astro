---
const navLinks = [
  { label: "Services", href: "/#services" },
  { label: "Why Us", href: "/#why-us" },
  { label: "Reviews", href: "/#reviews" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="bg-navy">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-4 px-6 py-6 md:flex-row md:justify-between">
    <!-- Logo + Business Name -->
    <a href="/" class="flex items-center gap-3">
      <span class="flex h-8 w-8 items-center justify-center rounded-full bg-copper text-sm font-bold text-white">
        {"{{business_name}}".charAt(0)}
      </span>
      <span class="text-sm font-bold text-white">{"{{business_name}}"}</span>
    </a>

    <!-- Nav Links -->
    <nav class="flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-gray-400 transition hover:text-white"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Copyright -->
    <p class="text-sm text-gray-500">
      &copy; 2026 {"{{business_name}}"}. All rights reserved.
    </p>
  </div>
</footer>
