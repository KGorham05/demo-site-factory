---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout title="Contact - {{business_name}}">
  <main>
    <section class="bg-blue-900 py-16 text-white">
      <div class="mx-auto max-w-5xl px-6 text-center">
        <h1 class="text-4xl font-bold">Contact Us</h1>
        <p class="mt-4 text-lg text-blue-200">
          Get a free estimate today
        </p>
      </div>
    </section>

    <section class="py-16">
      <div class="mx-auto grid max-w-5xl gap-12 px-6 md:grid-cols-2">
        <!-- Contact Form -->
        <div>
          <h2 class="mb-6 text-2xl font-bold">Send Us a Message</h2>
          <form class="space-y-4" action="#" method="POST">
            <div>
              <label for="name" class="mb-1 block text-sm font-medium text-gray-700">
                Full Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              />
            </div>
            <div>
              <label for="email" class="mb-1 block text-sm font-medium text-gray-700">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              />
            </div>
            <div>
              <label for="phone" class="mb-1 block text-sm font-medium text-gray-700">
                Phone
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              />
            </div>
            <div>
              <label for="message" class="mb-1 block text-sm font-medium text-gray-700">
                How can we help?
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full rounded-lg border border-gray-300 px-4 py-2 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full rounded-lg bg-blue-900 px-6 py-3 font-semibold text-white transition hover:bg-blue-800"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="mb-6 text-2xl font-bold">Get in Touch</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-semibold text-gray-900">Phone</h3>
              <a href="tel:{{phone}}" class="text-blue-700 hover:underline">{{phone}}</a>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Email</h3>
              <a href="mailto:{{email}}" class="text-blue-700 hover:underline">{{email}}</a>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Address</h3>
              <p class="text-gray-600">
                {{address}}<br />
                {{city}}, {{state}} {{zip}}
              </p>
            </div>
            <div>
              <h3 class="mb-2 font-semibold text-gray-900">Business Hours</h3>
              <table class="text-sm text-gray-600">
                <tr><td class="pr-4">Monday - Friday</td><td>8:00 AM - 5:00 PM</td></tr>
                <tr><td class="pr-4">Saturday</td><td>9:00 AM - 2:00 PM</td></tr>
                <tr><td class="pr-4">Sunday</td><td>Closed</td></tr>
              </table>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
