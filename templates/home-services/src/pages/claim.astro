---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout title="Make This Site Yours - {{business_name}}" hideDemoBanner={true}>
  <main>
    <!-- ==================== HERO ==================== -->
    <section class="bg-navy py-20 md:py-28">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-copper">Claim Your Website</p>
        <h1 class="mb-6 font-['Playfair_Display'] text-4xl font-black text-white md:text-5xl lg:text-6xl">
          Make This Site Yours
        </h1>
        <p class="mx-auto mb-4 max-w-2xl text-lg text-gray-300 md:text-xl">
          We built this custom website for <span class="font-semibold text-copper">{"{{business_name}}"}</span>.
          It's ready to go live on your own domain.
        </p>
        <p class="text-base text-gray-400">
          Choose a plan below and your site can be <span class="font-semibold text-white">live within 24 hours</span>.
        </p>
      </div>
    </section>

    <!-- ==================== HOW IT WORKS ==================== -->
    <section class="bg-gray-bg py-20 md:py-28">
      <div class="mx-auto max-w-5xl px-6">
        <div class="mb-16 text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-copper">Simple Process</p>
          <h2 class="font-['Playfair_Display'] text-3xl font-black text-gray-900 md:text-4xl">How It Works</h2>
        </div>

        <div class="grid gap-8 md:grid-cols-3">
          <!-- Step 1 -->
          <div class="relative rounded-xl border border-gray-200 bg-white p-8 text-center">
            <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-copper text-lg font-bold text-white">
              1
            </div>
            <h3 class="mb-2 text-lg font-bold text-gray-900">Choose Your Plan</h3>
            <p class="text-sm leading-relaxed text-gray-500">
              Pick the package that fits your needs. Every plan includes a fully customized, mobile-friendly website.
            </p>
          </div>

          <!-- Step 2 -->
          <div class="relative rounded-xl border border-gray-200 bg-white p-8 text-center">
            <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-copper text-lg font-bold text-white">
              2
            </div>
            <h3 class="mb-2 text-lg font-bold text-gray-900">Send Your Details</h3>
            <p class="text-sm leading-relaxed text-gray-500">
              After checkout, share your logo, photos, and any changes you'd like. We handle the rest.
            </p>
          </div>

          <!-- Step 3 -->
          <div class="relative rounded-xl border border-gray-200 bg-white p-8 text-center">
            <div class="mx-auto mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-copper text-lg font-bold text-white">
              3
            </div>
            <h3 class="mb-2 text-lg font-bold text-gray-900">Go Live</h3>
            <p class="text-sm leading-relaxed text-gray-500">
              We'll connect your domain, finalize the design, and launch your site — typically within 24 hours.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== WHAT WE NEED FROM YOU ==================== -->
    <section class="bg-white py-20 md:py-28">
      <div class="mx-auto max-w-5xl px-6">
        <div class="mb-16 text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-copper">Quick & Easy</p>
          <h2 class="font-['Playfair_Display'] text-3xl font-black text-gray-900 md:text-4xl">What We Need From You</h2>
          <p class="mx-auto mt-4 max-w-2xl text-base text-gray-500">
            Just a few things to personalize your site. Don't worry — we'll guide you through it.
          </p>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <!-- Card 1 -->
          <div class="flex items-start gap-4 rounded-xl border border-gray-200 bg-white p-6">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-emerald-100">
              <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="mb-1 font-bold text-gray-900">Verify Business Info</h3>
              <p class="text-sm text-gray-500">Confirm your name, phone, address, and hours are correct.</p>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="flex items-start gap-4 rounded-xl border border-gray-200 bg-white p-6">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-emerald-100">
              <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" />
              </svg>
            </div>
            <div>
              <h3 class="mb-1 font-bold text-gray-900">Logo & Photos</h3>
              <p class="text-sm text-gray-500">Send your logo and any team or project photos you'd like featured.</p>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="flex items-start gap-4 rounded-xl border border-gray-200 bg-white p-6">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-emerald-100">
              <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z" />
              </svg>
            </div>
            <div>
              <h3 class="mb-1 font-bold text-gray-900">Color Preferences</h3>
              <p class="text-sm text-gray-500">Let us know if you have brand colors or a color scheme you prefer.</p>
            </div>
          </div>

          <!-- Card 4 -->
          <div class="flex items-start gap-4 rounded-xl border border-gray-200 bg-white p-6">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-emerald-100">
              <svg class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
              </svg>
            </div>
            <div>
              <h3 class="mb-1 font-bold text-gray-900">Copy Changes</h3>
              <p class="text-sm text-gray-500">Any text updates — service descriptions, about section, or tagline tweaks.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== PRICING ==================== -->
    <section id="pricing" class="bg-gray-bg py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-16 text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-copper">Pricing</p>
          <h2 class="font-['Playfair_Display'] text-3xl font-black text-gray-900 md:text-4xl">Choose Your Plan</h2>
          <p class="mx-auto mt-4 max-w-2xl text-base text-gray-500">
            One-time payment. No monthly fees. Your website, fully owned by you.
          </p>
        </div>

        <div class="mx-auto grid max-w-4xl gap-8 md:grid-cols-2">
          <!-- Standard (highlighted) -->
          <div class="relative rounded-xl border-2 border-copper bg-white p-8 shadow-lg">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="rounded-full bg-copper px-4 py-1 text-xs font-bold text-white">Most Popular</span>
            </div>
            <h3 class="mb-1 text-lg font-bold text-gray-900">Standard</h3>
            <p class="mb-6 text-sm text-gray-500">Everything you need to get online fast.</p>
            <p class="mb-8">
              <span class="text-4xl font-black text-gray-900">$499</span>
              <span class="text-sm text-gray-500"> one-time</span>
            </p>
            <ul class="mb-8 space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Custom website with your branding
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Mobile-friendly design
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Domain setup assistance
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                2 hours of support for copy changes, logo, and feedback
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Basic SEO setup
              </li>
            </ul>
            <a
              href={"{{purchase_url_standard}}"}
              class="block rounded-full bg-copper px-6 py-3 text-center text-sm font-semibold text-white transition hover:bg-copper-dark"
            >
              Get Started
            </a>
          </div>

          <!-- Premium -->
          <div class="rounded-xl border border-gray-200 bg-white p-8">
            <h3 class="mb-1 text-lg font-bold text-gray-900">Premium</h3>
            <p class="mb-6 text-sm text-gray-500">Hands-on support for serious growth.</p>
            <p class="mb-8">
              <span class="text-4xl font-black text-gray-900">$999</span>
              <span class="text-sm text-gray-500"> one-time</span>
            </p>
            <ul class="mb-8 space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Everything in Standard
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                5 hours of dedicated support
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Professional copywriting
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Custom logo placement and design guidance
              </li>
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                Google Business Profile optimization
              </li>
            </ul>
            <a
              href={"{{purchase_url_premium}}"}
              class="block rounded-full border-2 border-copper px-6 py-3 text-center text-sm font-semibold text-copper transition hover:bg-copper hover:text-white"
            >
              Get Started
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== FAQ / REVISIONS ==================== -->
    <section class="bg-white py-20 md:py-28">
      <div class="mx-auto max-w-4xl px-6">
        <div class="mb-16 text-center">
          <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-copper">FAQ</p>
          <h2 class="font-['Playfair_Display'] text-3xl font-black text-gray-900 md:text-4xl">Common Questions</h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2">
          <div class="rounded-xl border border-gray-200 bg-white p-6">
            <h3 class="mb-2 font-bold text-gray-900">How do revisions work?</h3>
            <p class="text-sm leading-relaxed text-gray-500">
              After purchase, send us your changes and we'll update the site. Basic includes 1 round, Standard includes 3, and Premium includes unlimited revisions.
            </p>
          </div>

          <div class="rounded-xl border border-gray-200 bg-white p-6">
            <h3 class="mb-2 font-bold text-gray-900">How fast will my site be live?</h3>
            <p class="text-sm leading-relaxed text-gray-500">
              Most sites go live within 24 hours of receiving your details. Complex customizations may take 2-3 business days.
            </p>
          </div>

          <div class="rounded-xl border border-gray-200 bg-white p-6">
            <h3 class="mb-2 font-bold text-gray-900">Do I need a domain name?</h3>
            <p class="text-sm leading-relaxed text-gray-500">
              If you already have one, great! If not, we'll help you pick and register the perfect domain for your business.
            </p>
          </div>

          <div class="rounded-xl border border-gray-200 bg-white p-6">
            <h3 class="mb-2 font-bold text-gray-900">Are there monthly fees?</h3>
            <p class="text-sm leading-relaxed text-gray-500">
              No. The price you see is a one-time payment. You'll only pay standard domain and hosting costs (typically $10-20/year for a domain).
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== CONTACT ==================== -->
    <section class="bg-navy py-20 md:py-28">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-copper">Get in Touch</p>
        <h2 class="mb-4 font-['Playfair_Display'] text-3xl font-black text-white md:text-4xl">
          Questions? Let's Talk
        </h2>
        <p class="mx-auto mb-10 max-w-xl text-base text-gray-400">
          Not sure which plan is right for you? Have a question about the process? Reach out — we're happy to help.
        </p>

        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="mailto:{{owner_email}}"
            class="inline-flex items-center gap-2 rounded-full bg-copper px-8 py-3.5 text-sm font-semibold text-white transition hover:bg-copper-dark"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            {"{{owner_email}}"}
          </a>
          <a
            href="tel:{{owner_phone}}"
            class="inline-flex items-center gap-2 rounded-full border-2 border-copper px-8 py-3.5 text-sm font-semibold text-copper transition hover:bg-copper/10"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            {"{{owner_phone}}"}
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
