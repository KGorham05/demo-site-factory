---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout title="Reviews - {{business_name}}">
  <main>
    <section class="bg-blue-900 py-16 text-white">
      <div class="mx-auto max-w-5xl px-6 text-center">
        <h1 class="text-4xl font-bold">Customer Reviews</h1>
        <p class="mt-4 text-lg text-blue-200">
          See what our customers have to say
        </p>
        <div class="mt-6">
          <span class="text-5xl font-bold">{{rating}}</span>
          <span class="text-2xl text-blue-200">/5</span>
          <p class="mt-1 text-blue-200">Based on {{review_count}} reviews</p>
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="mx-auto max-w-3xl space-y-8 px-6">
        <!-- Testimonials will be generated from business.yaml -->
        <div class="rounded-lg border p-6 shadow-sm">
          <div class="mb-2 text-yellow-500">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="mb-4 text-gray-600">
            "{{testimonial_1_text}}"
          </p>
          <p class="font-semibold text-gray-900">- {{testimonial_1_author}}</p>
        </div>
        <div class="rounded-lg border p-6 shadow-sm">
          <div class="mb-2 text-yellow-500">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="mb-4 text-gray-600">
            "{{testimonial_2_text}}"
          </p>
          <p class="font-semibold text-gray-900">- {{testimonial_2_author}}</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-gray-50 py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="mb-4 text-3xl font-bold">Ready to Experience the Difference?</h2>
        <p class="mb-8 text-gray-600">
          Join our growing list of satisfied customers.
        </p>
        <a
          href="/contact"
          class="inline-block rounded-lg bg-blue-900 px-8 py-3 text-lg font-semibold text-white transition hover:bg-blue-800"
        >
          Get Your Free Estimate
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
