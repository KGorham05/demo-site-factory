---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout title="Services - {{business_name}}">
  <main>
    <section class="bg-blue-900 py-16 text-white">
      <div class="mx-auto max-w-5xl px-6 text-center">
        <h1 class="text-4xl font-bold">Our Services</h1>
        <p class="mt-4 text-lg text-blue-200">
          Professional {{industry}} services for your home
        </p>
      </div>
    </section>

    <section class="py-16">
      <div class="mx-auto max-w-5xl px-6">
        <div class="space-y-12">
          <!-- Service entries will be generated from business.yaml -->
          <div class="flex flex-col gap-6 md:flex-row md:items-start">
            <div class="flex-1">
              <h2 class="mb-3 text-2xl font-bold">{{service_1_name}}</h2>
              <p class="text-gray-600">{{service_1_description}}</p>
            </div>
          </div>
          <hr />
          <div class="flex flex-col gap-6 md:flex-row md:items-start">
            <div class="flex-1">
              <h2 class="mb-3 text-2xl font-bold">{{service_2_name}}</h2>
              <p class="text-gray-600">{{service_2_description}}</p>
            </div>
          </div>
          <hr />
          <div class="flex flex-col gap-6 md:flex-row md:items-start">
            <div class="flex-1">
              <h2 class="mb-3 text-2xl font-bold">{{service_3_name}}</h2>
              <p class="text-gray-600">{{service_3_description}}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-gray-50 py-16">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="mb-4 text-3xl font-bold">Need a Service Not Listed?</h2>
        <p class="mb-8 text-gray-600">
          Contact us to discuss your specific needs. We're happy to help.
        </p>
        <a
          href="/contact"
          class="inline-block rounded-lg bg-blue-900 px-8 py-3 text-lg font-semibold text-white transition hover:bg-blue-800"
        >
          Get in Touch
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
