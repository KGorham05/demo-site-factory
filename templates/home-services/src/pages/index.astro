---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout title="Home - Professional Home Services">
  <main>
    <!-- Hero Section -->
    <section class="bg-blue-900 py-20 text-white">
      <div class="mx-auto max-w-5xl px-6 text-center">
        <h1 class="mb-4 text-4xl font-bold md:text-5xl">
          {{business_name}}
        </h1>
        <p class="mb-8 text-xl text-blue-200">
          {{tagline}}
        </p>
        <a
          href="/contact"
          class="inline-block rounded-lg bg-yellow-500 px-8 py-3 text-lg font-semibold text-gray-900 transition hover:bg-yellow-400"
        >
          Get a Free Estimate
        </a>
      </div>
    </section>

    <!-- Trust Signals -->
    <section class="bg-gray-50 py-12">
      <div class="mx-auto flex max-w-5xl flex-wrap justify-center gap-8 px-6 text-center">
        <div>
          <p class="text-3xl font-bold text-blue-900">Licensed</p>
          <p class="text-gray-600">Fully licensed professionals</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-blue-900">Insured</p>
          <p class="text-gray-600">Complete liability coverage</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-blue-900">{{years_in_business}}+ Years</p>
          <p class="text-gray-600">Serving our community</p>
        </div>
      </div>
    </section>

    <!-- Services Overview -->
    <section class="py-16">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="mb-10 text-center text-3xl font-bold">Our Services</h2>
        <div class="grid gap-8 md:grid-cols-3">
          <!-- Service cards will be generated from business.yaml -->
          <div class="rounded-lg border p-6 text-center shadow-sm">
            <h3 class="mb-2 text-xl font-semibold">{{service_1_name}}</h3>
            <p class="text-gray-600">{{service_1_description}}</p>
          </div>
          <div class="rounded-lg border p-6 text-center shadow-sm">
            <h3 class="mb-2 text-xl font-semibold">{{service_2_name}}</h3>
            <p class="text-gray-600">{{service_2_description}}</p>
          </div>
          <div class="rounded-lg border p-6 text-center shadow-sm">
            <h3 class="mb-2 text-xl font-semibold">{{service_3_name}}</h3>
            <p class="text-gray-600">{{service_3_description}}</p>
          </div>
        </div>
        <div class="mt-8 text-center">
          <a href="/services" class="text-lg font-semibold text-blue-700 hover:underline">
            View All Services &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-blue-900 py-16 text-white">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="mb-4 text-3xl font-bold">Ready to Get Started?</h2>
        <p class="mb-8 text-lg text-blue-200">
          Call us today or fill out our contact form for a free, no-obligation estimate.
        </p>
        <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href="tel:{{phone}}"
            class="rounded-lg bg-yellow-500 px-8 py-3 text-lg font-semibold text-gray-900 transition hover:bg-yellow-400"
          >
            Call {{phone}}
          </a>
          <a
            href="/contact"
            class="rounded-lg border-2 border-white px-8 py-3 text-lg font-semibold transition hover:bg-white hover:text-blue-900"
          >
            Contact Us
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
